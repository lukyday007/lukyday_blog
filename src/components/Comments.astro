---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/LastUpdated.astro';
---

{/* 1. 원래 나오던 업데이트 날짜 */}
<Default {...Astro.props} />

{/* 2. 게시글 본문 폭에 맞춘 댓글창 */}
<div class="giscus-container">
  <script src="https://giscus.app/client.js"
          data-repo="lukyday007/lukyday_blog"
          data-repo-id="R_kgDORmJz6A"
          data-category="Announcements"
          data-category-id="DIC_kwDORmJz6M4C4Uat"
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="bottom"
          data-theme="preferred_color_scheme"
          data-lang="ko"
          crossorigin="anonymous"
          async>
  </script>
</div>

<style>
  .giscus-container {
    margin-top: 3rem;
    /* Starlight 본문 너비 제약을 따르도록 설정 */
    width: 100%;
  }

  /* Giscus 내부 프레임이 컨테이너 밖으로 나가지 않게 고정 */
  .giscus-container :global(iframe) {
    width: 100% !important;
  }
</style>