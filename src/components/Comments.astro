---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/LastUpdated.astro';
import Footer from './Footer.astro'; 

const url = Astro.url.pathname;
const isEnglish = url.includes('/en/');
const giscusLang = isEnglish ? 'en' : 'ko';

const publishedDate = Astro.props.entry?.data?.date;
const formattedDate = publishedDate 
  ? new Date(publishedDate).toLocaleDateString(
      isEnglish ? 'en-US' : 'ko-KR', 
      { year: 'numeric', month: 'long', day: 'numeric' }
    )
  : null;
---

<Default {...Astro.props} />

<p style="color: red;">{JSON.stringify(Object.keys(Astro.props))}</p>

{formattedDate && (
  <p class="published-date">
    {isEnglish ? `Published: ${formattedDate}` : `작성일: ${formattedDate}`}
  </p>
)}

<Footer />

<div class="giscus-container">
  <div id="giscus-slot"></div>
</div>

<script is:inline define:vars={{ giscusLang }}>
  function loadGiscus() {
    const slot = document.getElementById('giscus-slot');
    if (!slot) return;
    
    slot.innerHTML = '';
    
    const script = document.createElement('script');
    script.src = "https://giscus.app/client.js";
    script.dataset.repo = "lukyday007/lukyday_blog";
    script.dataset.repoId = "R_kgDORmJz6A";
    script.dataset.category = "Announcements";
    script.dataset.categoryId = "DIC_kwDORmJz6M4C4Uat";
    script.dataset.mapping = "pathname";
    script.dataset.strict = "0";
    script.dataset.reactionsEnabled = "1";
    script.dataset.emitMetadata = "0";
    script.dataset.inputPosition = "bottom";
    script.dataset.theme = "preferred_color_scheme";
    script.dataset.lang = giscusLang;
    script.crossOrigin = "anonymous";
    script.async = true;

    slot.appendChild(script);
  }

  loadGiscus();
  document.addEventListener('astro:after-swap', loadGiscus);
</script>

<style>
  .giscus-container {
    margin-top: 3rem;
    width: 100%;
  }
  .published-date {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    margin-top: 0.5rem;
  }
</style>